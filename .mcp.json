{
  "mcpServers": {
    "edgartools": {
      "type": "stdio",
      "command": "/bin/bash",
      "args": [
        "scripts/mcp/edgartools.sh"
      ],
      "env": {
        "EDGAR_IDENTITY": "${EDGAR_IDENTITY:-}"
      }
    },
    "arxiv": {
      "type": "stdio",
      "command": "/bin/bash",
      "args": [
        "scripts/mcp/arxiv.sh"
      ]
    },
    "youtube-transcript": {
      "type": "stdio",
      "command": "/bin/bash",
      "args": [
        "scripts/mcp/youtube-transcript.sh"
      ],
      "env": {
        "YOUTUBE_COOKIES_FROM_BROWSER": "${YOUTUBE_COOKIES_FROM_BROWSER:-}"
      }
    }
  }
}
