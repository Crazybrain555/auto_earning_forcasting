{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceRecord",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "source_id",
    "source_type",
    "publisher",
    "published_at",
    "retrieved_at",
    "period_scope",
    "evidence_tier",
    "content_hash",
    "location"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string"
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "period_scope": {
      "type": "string"
    },
    "evidence_tier": {
      "enum": [
        "E0",
        "E1",
        "E2",
        "E3",
        "E4"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "location": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
