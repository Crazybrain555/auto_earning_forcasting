{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Technology forecast run manifest",
  "type": "object",
  "required": [
    "run_id",
    "entity",
    "security",
    "as_of",
    "purpose",
    "fiscal_calendar",
    "currency",
    "accounting_basis",
    "horizons",
    "selected_mechanisms",
    "readiness_target",
    "phase_status"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "entity": {
      "type": "string"
    },
    "security": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "fiscal_calendar": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "accounting_basis": {
      "type": "string"
    },
    "horizons": {
      "type": "object"
    },
    "selected_mechanisms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readiness_target": {
      "type": "string"
    },
    "phase_status": {
      "type": "object"
    },
    "human_required": {
      "type": "array"
    },
    "validation_results": {
      "type": "object"
    }
  }
}
