{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BacktestResult",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "metrics",
    "legacy_threshold_diagnostics"
  ],
  "properties": {
    "model_version": {
      "type": "string"
    },
    "benchmark_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object"
    },
    "legacy_threshold_diagnostics": {
      "type": "object",
      "required": ["artifact", "diagnostic_only", "promotion_authority"],
      "properties": {
        "artifact": {"const": "diagnostics.json"},
        "diagnostic_only": {"const": true},
        "promotion_authority": {"const": "none"}
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
