{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model_checks.schema.json",
  "title": "Executable model checks v2",
  "type": "object",
  "required": ["schema_version", "checks"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "calculation", "value", "tolerance", "unit", "status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "calculation": {
            "type": "object",
            "required": ["operation", "terms"],
            "properties": {
              "operation": {"const": "signed_sum"},
              "terms": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "coefficient", "model_cell"],
                  "properties": {
                    "name": {"type": "string", "minLength": 1},
                    "coefficient": {"type": "number"},
                    "model_cell": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          },
          "value": {"type": "number"},
          "tolerance": {"type": "number", "minimum": 0},
          "unit": {"type": "string", "minLength": 1},
          "status": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
