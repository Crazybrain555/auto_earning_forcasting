{
  "schema_version": "forecast-method-system/v1",
  "method_id": "technology-company-causal-value-system",
  "method_version": "10.0.0",
  "title": "Evidence-to-Value Technology Company Forecasting System",
  "title_zh": "从证据到价值的科技公司预测系统",
  "canonical_flow": [
    "dated_evidence",
    "causal_dag",
    "operating_equations",
    "integrated_three_statements",
    "conditional_earnings_persistence_bridge",
    "roic_reinvestment_fade",
    "valuation_reverse_implied_expectations",
    "red_team",
    "monitoring"
  ],
  "judgment_boundary": {
    "allowed": [
      "main_line_and_rival_hypothesis_selection",
      "named_scenario_design_and_probabilities",
      "required_return",
      "margin_of_safety_and_posture"
    ],
    "prohibited": [
      "manual_importance_weights",
      "unexplained_cagr_or_margin_plugs",
      "balancing_plugs",
      "evidence_scores_presented_as_truth"
    ]
  },
  "construction_philosophy": {
    "primary_control": "stage_order_and_correct_by_construction_sop",
    "canonical_sop": "references/research-sop.md",
    "authored_once": [
      "decision_and_hypothesis_contract",
      "source_claim_observation_and_financial_fact_ledgers",
      "typed_causal_equation_graph",
      "named_scenario_overrides",
      "explicit_judgment_inputs"
    ],
    "generated_or_reconciled_views": [
      "historical_and_operating_schedules",
      "scenario_profit_paths",
      "integrated_statements",
      "earnings_power_and_valuation",
      "workbook_snapshot_report_and_monitors"
    ],
    "complexity_rule": "add detail only when it changes a material revenue operating-profit or attributable-net-income distribution, distinguishes a rival hypothesis, or prevents a demonstrated data/accounting failure",
    "equation_count_target": null,
    "artifact_count_target": null,
    "test_count_target": null
  },
  "assurance_philosophy": {
    "tests_are": "orthogonal_views_not_a_completeness_score",
    "deterministic_scope": [
      "source_dates_vintages_and_scope",
      "provenance_and_types",
      "equation_execution",
      "accounting_conservation",
      "evidence_to_conclusion_referential_integrity"
    ],
    "independent_agent_scope": [
      "economic_causality_and_principal_contradiction",
      "evidence_interpretation_and_noise",
      "rival_hypotheses_and_disconfirmation",
      "technology_to_production_transfer",
      "persistence_moat_and_mean_reversion",
      "investment_relevance_and_clarity"
    ],
    "orthogonal_angles": [
      "economic_causality",
      "evidence_and_data",
      "accounting_and_execution",
      "disconfirmation_and_investment_relevance",
      "clarity_and_reproducibility"
    ],
    "duplicate_rule": "consolidate tests that respond to the same underlying defect",
    "independence_rule": "freeze evidence and model before an isolated reviewer records findings; role labels or duplicated prompts do not establish independence",
    "complexity_change_contract": [
      "distinct_failure_addressed",
      "primary_assurance_angle",
      "overlapping_rule_retired_or_reason_none_exists",
      "ablation_or_retirement_condition"
    ]
  },
  "mandatory_decision_schedules": {
    "applies_to_read_only_memos": true,
    "human_required_preserves_rows_and_blocks_conclusions": true,
    "integrated_three_statement_minimum": {
      "trigger": "full_company_or_three_year_or_longer_forecast_or_valuation",
      "narrow_review_rule": "materiality_bounded",
      "required_roll_forwards": [
        "ppe_and_depreciation",
        "operating_working_capital",
        "debt_and_cash",
        "financing_dilution_and_basic_diluted_shares"
      ],
      "required_checks": [
        "cfs_to_balance_sheet_cash",
        "assets_equal_liabilities_plus_equity",
        "revenue_to_operating_profit",
        "operating_profit_to_pretax_profit",
        "pretax_tax_nci_to_gaap_attributable_net_income",
        "forecast_period_coverage_across_integrated_snapshot_and_earnings_bridge"
      ]
    },
    "every_full_company_model": [
      "document_observation_and_financial_fact_lineage",
      "material_series_cross_check_strategy_and_honest_corroboration_status",
      "reported_normalized_cash_accrual_investment_cycle_profit_bridge"
    ],
    "three_year_or_valuation": [
      "normalized_nopat_average_and_incremental_roic_reinvestment_growth",
      "conditional_earnings_persistence_and_mean_reversion",
      "causal_competition_and_obsolescence_fade",
      "cell_date_threshold_action_monitoring"
    ],
    "material_technology_or_ip": [
      "patent_claim_ownership_encumbrance_family_citation_fto",
      "claim_to_driver_node_to_economic_permission"
    ],
    "recurring_or_usage": [
      "cohort_arr_nrr_without_double_counting",
      "usage_hosting_support_unit_costs",
      "deferred_ar_ap_capitalized_development_diluted_share_rolls",
      "case_selected_material_driver_scenarios_reexecuted_through_one_model"
    ]
  },
  "profiles": {
    "live": {
      "purpose": "Continuously incorporate current evidence through bundle freeze, then publish a versioned forecast, valuation and monitoring state",
      "extra_stages": []
    }
  },
  "optional_calibration": {
    "glob": "references/lens-*.md",
    "core_dependency": false,
    "authority": "calibration_example_only"
  },
  "stages": [
