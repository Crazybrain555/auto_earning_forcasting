  "forecast_methodology": {
    "annual_revenue_formula": "revenue_t = revenue_t_minus_1 * (1 + bit_growth_t) * (asp_index_t / asp_index_t_minus_1)",
    "gross_profit_formula": "gross_profit_t = revenue_t * gross_margin_t",
    "operating_income_formula": "operating_income_t = gross_profit_t - operating_expenses_t",
    "pretax_income_formula": "pretax_income_t = operating_income_t + other_income_t",
    "net_income_formula": "net_income_t = pretax_income_t * (1 - tax_rate_t)",
    "diluted_eps_formula": "diluted_eps_t = net_income_t / diluted_shares_t",
    "edge_share_formula": "edge_share_t = 1 - datacenter_share_t - consumer_share_t",
    "annual_starting_point": {
      "period": "FY2026E",
      "revenue": 19283,
      "asp_index": 75,
      "cost_index": 100
    },
    "valuation_formula": "scenario_value_per_share = transition_weight * transition_PE * FY2027E_EPS + normalized_weight * normalized_PE * average(FY2029E_EPS, FY2030E_EPS) + excess_cash_per_share",
    "probability_weighted_value_formula": "sum(scenario_probability * scenario_value_per_share)"
  },
