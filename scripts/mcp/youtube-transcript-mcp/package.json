{
  "name": "ai-stock-framework-youtube-transcript-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Project-scoped MCP server for public YouTube search and subtitles only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
